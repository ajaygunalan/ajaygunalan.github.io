	volume = {99},
	issn = {0948-7921, 1432-0487},
	url = {http://link.springer.com/10.1007/s00202-016-0444-8},
	doi = {10.1007/s00202-016-0444-8},
	abstract = {This paper investigates the dynamic properties and chaos control in a fractional order brushless DC (BLDC) motor. The fractional order model of the brushless DC motor has been derived from its integer order model. Then the qualitative properties of the fractional order BLDC motor are derived. Bifurcation analysis of the BLDC motor with the fractional order has been also discussed. Fractional order chaos control in the BLDC motor is achieved using sliding mode control, robust control and extended back-stepping control.},
	language = {en},
	number = {2},
	urldate = {2018-08-24},
	journal = {Electrical Engineering},
	author = {Rajagopal, Karthikeyan and Vaidyanathan, Sundarapandian and Karthikeyan, Anitha and Duraisamy, Prakash},
	month = jun,
	year = {2017},
	keywords = {BLDC, chaos},
	pages = {721--733},
	file = {Rajagopal et al. - 2017 - Dynamic analysis and chaos suppression in a fracti.pdf:/home/ajay/Zotero/storage/GEMUGQ7J/Rajagopal et al. - 2017 - Dynamic analysis and chaos suppression in a fracti.pdf:application/pdf}
}

